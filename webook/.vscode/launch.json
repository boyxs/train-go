  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "APP_ENV": "config/local.yaml", // 本地调试默认；CI/dev 服务器改 config/dev.yaml；生产用 config/prod.yaml
        "GOMEMLIMIT": "512MiB",
        "GOGC": "80"
      },
      // "args": ["--env=config/local.yaml"], //优先于env
    }
  ]
}
