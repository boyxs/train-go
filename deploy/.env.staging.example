# ===================================================
# staging 环境变量模板
# ===================================================
GH_USER=your-github-username
CORE_IMAGE_TAG=master-latest
CHAT_IMAGE_TAG=master-latest
FE_IMAGE_TAG=master-latest
GHCR_REGISTRY=ghcr.io

CORE_APP_ENV=config/staging.yaml
CHAT_APP_ENV=config/staging.yaml
DEPLOY_ENV=staging

MYSQL_PASS=CHANGE_ME
REDIS_PASS=CHANGE_ME

# ── 业务/中间件内存（贴近 prod）
# Go 服务：mem_limit 是 cgroup 硬限，GOMEMLIMIT 是 Go 软限（应比 mem_limit 留 ~12% buffer 给堆外），GOGC=80 比默认 100 激进
CORE_MEM=512m
CORE_GOMEMLIMIT=450MiB
CORE_GOGC=80
CHAT_MEM=384m
CHAT_GOMEMLIMIT=320MiB
CHAT_GOGC=80
MYSQL_MEM=1024m
REDIS_MEM=256m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9194

# ── Etcd（切到官方 quay.io/coreos/etcd 后 ALLOW_NONE / PASS 不再使用，保留供切回 bitnami 镜像时用）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
ETCD_MEM=128m

# ── 宿主端口（和 dev 错开，同机可切换不冲突）
NGINX_PORT=81
PROMETHEUS_PORT=9190
GRAFANA_PORT=3011
ZIPKIN_PORT=9412
# CHAT_HOST_PORT=8189   # 仅 local override 用；server 模式 chat 走 docker 内网 + nginx，无需暴露

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
