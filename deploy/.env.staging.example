# ===================================================
# staging 环境变量模板
# ===================================================

# ── 镜像与发布 ─────────────────────────────────────────
GH_USER=your-github-username
GHCR_REGISTRY=ghcr.io
CORE_IMAGE_TAG=main-latest
CHAT_IMAGE_TAG=main-latest
COMMENT_IMAGE_TAG=main-latest
INTERACTION_IMAGE_TAG=main-latest
MIGRATOR_IMAGE_TAG=main-latest
WORKER_IMAGE_TAG=main-latest
FE_IMAGE_TAG=main-latest

# ── 环境选择（APP_ENV 决定加载哪份 yaml） ─────────────────────
CORE_APP_ENV=config/staging.yaml
CHAT_APP_ENV=config/staging.yaml
COMMENT_APP_ENV=config/staging.yaml
INTERACTION_APP_ENV=config/staging.yaml
MIGRATOR_APP_ENV=config/staging.yaml
WORKER_APP_ENV=config/staging.yaml
DEPLOY_ENV=staging

# ── 密码 / 密钥（敏感，勿提交真实值；集中便于审计与轮换） ──────────────────
# 自建中间件
MYSQL_PASS=CHANGE_ME
REDIS_PASS=CHANGE_ME
CANAL_PASS=CHANGE_ME
# etcd 认证（切官方 quay.io/coreos/etcd 后不用，保留供切回 bitnami 镜像）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
# Grafana 登录 + SMTP 授权码
GRAFANA_PASS=admin
GRAFANA_SMTP_PASSWORD=
# 外部 LLM / Embedding
LLM_DEEPSEEK_API_KEY=
LLM_KIMI_API_KEY=
EMBEDDING_API_KEY=

# ── 内存 / 堆 ────────────────────────────────────────
# 业务服务（Go：mem_limit cgroup 硬限 / GOMEMLIMIT 软限留 ~12% buffer 给堆外 / GOGC=80 比默认 100 激进）
CORE_MEM=512m
CORE_GOMEMLIMIT=450MiB
CORE_GOGC=80
CHAT_MEM=384m
CHAT_GOMEMLIMIT=320MiB
CHAT_GOGC=80
COMMENT_MEM=384m
COMMENT_GOMEMLIMIT=320MiB
COMMENT_GOGC=80
MIGRATOR_MEM=384m
MIGRATOR_GOMEMLIMIT=320MiB
MIGRATOR_GOGC=80
# 中间件
MYSQL_MEM=1024m
REDIS_MEM=256m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m
ETCD_MEM=128m
# 监控栈
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── 端口 / 网络 ───────────────────────────────────────
NGINX_PORT=81
PROMETHEUS_PORT=9190
GRAFANA_PORT=3011
# grafana root_url（告警邮件链接用）；经域名/HTTPS 访问改完整 URL，如 https://monitor.webook.com/
GRAFANA_ROOT_URL=http://localhost:3011/
ZIPKIN_PORT=9412
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9194
# CHAT_HOST_PORT=8020   # 仅 local override 用；server 模式 chat 走 docker 内网 + nginx，无需暴露

# ── Grafana / 告警（非敏感） ─────────────────────────────
GRAFANA_USER=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
