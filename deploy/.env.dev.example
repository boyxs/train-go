# ===================================================
# dev 环境变量模板
# ===================================================
GH_USER=your-github-username
IMAGE_TAG=master-latest
FE_IMAGE_TAG=master-latest
GHCR_REGISTRY=ghcr.io

APP_ENV=config/dev.yaml
DEPLOY_ENV=dev

MYSQL_PASS=CHANGE_ME
REDIS_PASS=CHANGE_ME

# ── 业务/中间件内存
MYSQL_MEM=768m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=768m
ES_HEAP=-Xms384m -Xmx384m
FE_MEM=384m
OLLAMA_MEM=1024m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener（填部署机 IP；用不到可留 localhost）
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094

# ── Etcd（切到官方 quay.io/coreos/etcd 后 ALLOW_NONE / PASS 不再使用，保留供切回 bitnami 镜像时用）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
ETCD_MEM=128m

# ── 宿主端口（dev 用默认即可；想避开本地占用可以改）
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ZIPKIN_PORT=9411

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
