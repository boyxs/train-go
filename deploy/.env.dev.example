# ===================================================
# dev 环境变量模板
# ===================================================

# ── 镜像与发布 ─────────────────────────────────────────
GH_USER=your-github-username
GHCR_REGISTRY=ghcr.io
CORE_IMAGE_TAG=main-latest
CHAT_IMAGE_TAG=main-latest
COMMENT_IMAGE_TAG=main-latest
INTERACTION_IMAGE_TAG=main-latest
RELATION_IMAGE_TAG=main-latest
TAG_IMAGE_TAG=main-latest
SEARCH_IMAGE_TAG=main-latest
MIGRATOR_IMAGE_TAG=main-latest
WORKER_IMAGE_TAG=main-latest
FE_IMAGE_TAG=main-latest

# ── 环境选择（APP_ENV 决定加载哪份 yaml） ─────────────────────
CORE_APP_ENV=config/dev.yaml
CHAT_APP_ENV=config/dev.yaml
COMMENT_APP_ENV=config/dev.yaml
INTERACTION_APP_ENV=config/dev.yaml
RELATION_APP_ENV=config/dev.yaml
TAG_APP_ENV=config/dev.yaml
SEARCH_APP_ENV=config/dev.yaml
MIGRATOR_APP_ENV=config/dev.yaml
WORKER_APP_ENV=config/dev.yaml
DEPLOY_ENV=dev

# ── 密码 / 密钥（敏感，勿提交真实值；集中便于审计与轮换） ──────────────────
# 自建中间件
MYSQL_PASS=CHANGE_ME
REDIS_PASS=CHANGE_ME
# 固定 canal（写死在 mysql/init/01-canal-user.sql）
CANAL_PASS=canal
ES_PASS=CHANGE_ME           # ES 内置 elastic 用户密码（≥6 位）；webook-es ELASTIC_PASSWORD + core/migrator data.es.password
# etcd 认证（切官方 quay.io/coreos/etcd 后不用，保留供切回 bitnami 镜像）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
# Grafana 登录 + SMTP 授权码
GRAFANA_PASS=admin
GRAFANA_SMTP_PASSWORD=
# 外部 LLM / Embedding
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QIANFAN_API_KEY=

# ── 内存 / 堆 ────────────────────────────────────────
# 业务服务（Go：mem_limit cgroup 硬限 / GOMEMLIMIT 软限留 ~12% buffer 给堆外 / GOGC=80 比默认 100 激进）
CORE_MEM=384m
CORE_GOMEMLIMIT=320MiB
CORE_GOGC=80
CHAT_MEM=256m
CHAT_GOMEMLIMIT=200MiB
CHAT_GOGC=80
COMMENT_MEM=256m
COMMENT_GOMEMLIMIT=200MiB
COMMENT_GOGC=80
MIGRATOR_MEM=256m
MIGRATOR_GOMEMLIMIT=200MiB
MIGRATOR_GOGC=80
# 中间件
MYSQL_MEM=768m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
# ↑ 复用 webook-es 放日志索引，dev 堆上调（检索 + 日志共节点）
FE_MEM=384m
OLLAMA_MEM=1024m
ETCD_MEM=128m
# 监控栈
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m
# 日志栈 ELK（opt-in：COMPOSE_PROFILES=elk ./deploy.sh dev；首次跑 ./elk/es/setup.sh 建 ILM+模板）
LOGSTASH_MEM=768m
LOGSTASH_HEAP=-Xms384m -Xmx384m
KIBANA_MEM=768m
FILEBEAT_MEM=256m
KIBANA_ENCKEY=CHANGE_ME_kibana_enc_key_min_32_chars
LOG_RETENTION_DAYS=7

# ── 端口 / 网络 ───────────────────────────────────────
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# grafana root_url（告警邮件链接用）；经域名/HTTPS 访问改完整 URL，如 https://monitor.webook.com/
GRAFANA_ROOT_URL=http://localhost:3001/
ZIPKIN_PORT=9411
KIBANA_PORT=5601             # Kibana UI（ELK profile；Kibana 自带账号登录）
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094
# CHAT_HOST_PORT=8020   # 仅 local override 用；server 模式 chat 走 docker 内网 + nginx，无需暴露

# ── Grafana / 告警（非敏感） ─────────────────────────────
GRAFANA_USER=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
