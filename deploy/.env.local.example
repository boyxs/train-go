# ===================================================
# local 环境变量模板（本地开发，走 build 而非 pull 镜像）
# 服务器用法：cp .env.local.example .env.local
# 所有 *_MEM / *_PORT / *_HEAP 都有默认值（compose 里 ${VAR:-default}），没覆盖就吃默认
# ===================================================

# ── 镜像（local 模式 build，下面六项占位即可，不读）

# ── 镜像与发布 ─────────────────────────────────────────
GH_USER=local
GHCR_REGISTRY=ghcr.io
CORE_IMAGE_TAG=local
CHAT_IMAGE_TAG=local
COMMENT_IMAGE_TAG=local
INTERACTION_IMAGE_TAG=local
RELATION_IMAGE_TAG=local
TAG_IMAGE_TAG=local
SEARCH_IMAGE_TAG=local
MIGRATOR_IMAGE_TAG=local
WORKER_IMAGE_TAG=local
FE_IMAGE_TAG=local

# ── 环境选择（APP_ENV 决定加载哪份 yaml） ─────────────────────
CORE_APP_ENV=config/dev.yaml      # local.yaml 走 localhost，容器内用 dev.yaml（service name）
CHAT_APP_ENV=config/dev.yaml      # chat 服务（与 core 同 yaml 形式）
COMMENT_APP_ENV=config/dev.yaml
INTERACTION_APP_ENV=config/dev.yaml
RELATION_APP_ENV=config/dev.yaml
TAG_APP_ENV=config/dev.yaml
SEARCH_APP_ENV=config/dev.yaml
MIGRATOR_APP_ENV=config/dev.yaml  # migrator 服务（与 core 同 yaml 形式）
WORKER_APP_ENV=config/dev.yaml
DEPLOY_ENV=local

# ── 密码 / 密钥（敏感，勿提交真实值；集中便于审计与轮换） ──────────────────
# 自建中间件
MYSQL_PASS=13520
REDIS_PASS=13520
# 固定 canal（写死在 mysql/init/01-canal-user.sql）
CANAL_PASS=canal
ES_PASS=elastic       # ES 内置 elastic 用户密码（≥6 位）；webook-es ELASTIC_PASSWORD + core/migrator data.es.password
# etcd 认证（切官方 quay.io/coreos/etcd 后不用，保留供切回 bitnami 镜像）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
# Grafana 登录 + SMTP 授权码
GRAFANA_PASS=admin
GRAFANA_SMTP_PASSWORD=
# 外部 LLM / Embedding
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QIANFAN_API_KEY=

# ── 内存 / 堆 ────────────────────────────────────────
# 业务服务（Go：mem_limit cgroup 硬限 / GOMEMLIMIT 软限留 ~12% buffer 给堆外 / GOGC=80 比默认 100 激进）
CORE_MEM=512m
CORE_GOMEMLIMIT=450MiB
CORE_GOGC=80
CHAT_MEM=384m
CHAT_GOMEMLIMIT=320MiB
CHAT_GOGC=80
COMMENT_MEM=384m
COMMENT_GOMEMLIMIT=320MiB
COMMENT_GOGC=80
MIGRATOR_MEM=384m
MIGRATOR_GOMEMLIMIT=320MiB
MIGRATOR_GOGC=80
# 中间件
MYSQL_MEM=1024m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m
ETCD_MEM=128m
# 监控栈
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── 端口 / 网络 ───────────────────────────────────────
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# grafana root_url（告警邮件链接用）；经域名/HTTPS 访问改完整 URL，如 https://monitor.webook.com/
GRAFANA_ROOT_URL=http://localhost:3001/
ZIPKIN_PORT=9411
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094
# 本地宿主端口映射（仅 local：暴露容器端口给 go run / DBeaver / 浏览器）
CORE_HOST_PORT=8010
CHAT_HOST_PORT=8020
COMMENT_HOST_PORT=8030
INTERACTION_HOST_PORT=8040
RELATION_HOST_PORT=8060
TAG_HOST_PORT=8070
SEARCH_HOST_PORT=8080
MIGRATOR_HOST_PORT=8200
WORKER_HOST_PORT=8050
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
ETCD_HOST_PORT=2379
KAFKA_HOST_PORT=9092
KAFKA_EXTERNAL_HOST_PORT=9094
ES_HOST_PORT=9200
OLLAMA_HOST_PORT=11434
OTEL_HOST_PORT=4317

# ── Grafana / 告警（非敏感） ─────────────────────────────
GRAFANA_USER=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
