# ===================================================
# local 环境变量模板（本地开发，走 build 而非 pull 镜像）
# 服务器用法：cp .env.local.example .env.local
# 所有 *_MEM / *_PORT / *_HEAP 都有默认值（compose 里 ${VAR:-default}），没覆盖就吃默认
# ===================================================

# ── 镜像（local 模式 build，下面四项占位即可，不读）
GH_USER=local
CORE_IMAGE_TAG=local
CHAT_IMAGE_TAG=local
MIGRATOR_IMAGE_TAG=local
FE_IMAGE_TAG=local
GHCR_REGISTRY=ghcr.io

# ── webook-core 应用配置（主仓服务）
CORE_APP_ENV=config/dev.yaml      # local.yaml 走 localhost，容器内用 dev.yaml（service name）
CHAT_APP_ENV=config/dev.yaml      # chat 服务（与 core 同 yaml 形式）
MIGRATOR_APP_ENV=config/dev.yaml  # migrator 服务（与 core 同 yaml 形式）
DEPLOY_ENV=local

# ── 凭证（必须和 webook/config/<env>.yaml 里 mysql.dsn / redis.password 的值一致）
MYSQL_PASS=13520
REDIS_PASS=13520

# ── 业务/中间件内存
# Go 服务：mem_limit 是 cgroup 硬限，GOMEMLIMIT 是 Go 软限（应比 mem_limit 留 ~12% buffer 给堆外），GOGC=80 比默认 100 激进
CORE_MEM=512m
CORE_GOMEMLIMIT=450MiB
CORE_GOGC=80
CHAT_MEM=384m
CHAT_GOMEMLIMIT=320MiB
CHAT_GOGC=80
MIGRATOR_MEM=384m
MIGRATOR_GOMEMLIMIT=320MiB
MIGRATOR_GOGC=80
MYSQL_MEM=1024m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener（主机访问 kafka 的 advertised 地址）
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094

# ── Etcd（切到官方 quay.io/coreos/etcd 后 ALLOW_NONE / PASS 不再使用，保留供切回 bitnami 镜像时用）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=13520
ETCD_MEM=128m

# ── 宿主端口映射（local 模式特有，local override 读）
CORE_HOST_PORT=8089
MIGRATOR_HOST_PORT=8083
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
ETCD_HOST_PORT=2379
KAFKA_HOST_PORT=9092
KAFKA_EXTERNAL_HOST_PORT=9094
ES_HOST_PORT=9200
OLLAMA_HOST_PORT=11434
OTEL_HOST_PORT=4317
# 下面几个 base compose 也会读（监控栈端口）
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ZIPKIN_PORT=9411

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
