{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "title": "Webook Jobs (Example Template)",
  "uid": "webook-jobs-example",
  "tags": [
    "webook",
    "jobs",
    "cron",
    "lock"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "task",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(webook_core_cron_runs_total, task)",
          "refId": "Variable"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Cron 任务数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(count by (task) (webook_core_cron_runs_total))",
          "legendFormat": "tasks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "所有曾有过 success Counter 的 task 数；不含从未运行的 task"
    },
    {
      "title": "Cron 成功率 (5m avg)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "avg(webook:cron_success_rate:rate5m) * 100",
          "legendFormat": "success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "复用 recording rule webook:cron_success_rate:rate5m，跨所有 task 平均"
    },
    {
      "title": "Lock Acquire QPS",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(webook_core_lock_acquire_total[5m]))",
          "legendFormat": "qps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "抢锁速率（含 success/busy/error），看锁热度"
    },
    {
      "title": "Watchdog Lost (1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(webook_core_lock_watchdog_lost_total[1h]))",
          "legendFormat": "lost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "一小时内 watchdog 续约失败次数；> 0 触发告警 webook-lock-watchdog-lost"
    },
    {
      "title": "Cron Runs by Task & Result",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (task, result) (rate(webook_core_cron_runs_total{task=~\"$task\"}[5m]))",
          "legendFormat": "{{task}} / {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "description": "Stacked bar：分 task + result 看分布；result 有 success/failed/skipped/panic"
    },
    {
      "title": "Cron In-Flight by Task",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "webook_core_cron_in_flight{task=~\"$task\"}",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "正常单机 <= 1；> 1 暗示锁失效或任务卡死（见告警 webook-cron-in-flight-stuck）"
    },
    {
      "title": "Cron Duration P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "webook:cron_duration_p50:rate5m{task=~\"$task\"}",
          "legendFormat": "P50 {{task}}"
        },
        {
          "expr": "webook:cron_duration_p95:rate5m{task=~\"$task\"}",
          "legendFormat": "P95 {{task}}"
        },
        {
          "expr": "webook:cron_duration_p99:rate5m{task=~\"$task\"}",
          "legendFormat": "P99 {{task}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "三分位数对比；P99 用 recording rule，P50/P95 现算"
    },
    {
      "title": "Last Success Age by Task",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "webook:cron_last_success_age:seconds{task=~\"$task\"}",
          "legendFormat": "{{task}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        },
        "overrides": []
      },
      "description": "距上次成功秒数；红色阈 600s 与告警 webook-cron-stale 对齐"
    },
    {
      "title": "Lock Acquire by Result",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(webook_core_lock_acquire_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "description": "Stacked：success/busy/error；error 高 = Redis 出问题"
    },
    {
      "title": "Lock Acquire Error Rate (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "webook:lock_acquire_error_rate:rate5m * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "line+area"
            }
          }
        },
        "overrides": []
      },
      "description": "复用 recording rule webook:lock_acquire_error_rate:rate5m"
    },
    {
      "title": "Lock Wait Seconds (Heatmap)",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(webook_core_lock_wait_seconds_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "阻塞 Lock 等待时长分布；尾部异常 = 锁热点"
    },
    {
      "title": "Lock Held Seconds (Heatmap)",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(webook_core_lock_held_seconds_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "锁持有时长 = 业务执行时长；过长可能要重新评估 lockTTL"
    },
    {
      "title": "Watchdog Lost Total",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "webook_core_lock_watchdog_lost_total",
          "legendFormat": "lost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "累计计数；正常 0，任意正值都该排查"
    },
    {
      "title": "Lock Wait P50 vs P99",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 36
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(webook_core_lock_wait_seconds_bucket[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "webook:lock_wait_p99:rate5m",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "description": "P50 P99 同图：尾部 vs 中位数差距越大越说明有少数慢请求"
    }
  ]
}