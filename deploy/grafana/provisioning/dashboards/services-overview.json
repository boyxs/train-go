{
  "uid": "services-overview",
  "title": "服务总览（存活 + 资源 + 业务）",
  "tags": ["webook", "overview", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "服务存活（up）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "所有 Target 存活",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up", "legendFormat": "{{job}} / {{instance}}" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "orientation": "horizontal",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },

    {
      "type": "row",
      "title": "主机资源（node-exporter）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "CPU 使用率",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "type": "gauge",
      "title": "内存使用率",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "type": "gauge",
      "title": "根分区使用率",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "type": "stat",
      "title": "Load Average (1m / 5m / 15m)",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m" },
        { "expr": "node_load5", "legendFormat": "5m" },
        { "expr": "node_load15", "legendFormat": "15m" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "orientation": "horizontal" }
    },
    {
      "type": "timeseries",
      "title": "网络吞吐（rx/tx）",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(device) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "rx {{device}}" },
        { "expr": "sum by(device) (rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "tx {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "type": "timeseries",
      "title": "磁盘 IO",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(device) (rate(node_disk_read_bytes_total[5m]))", "legendFormat": "read {{device}}" },
        { "expr": "sum by(device) (rate(node_disk_written_bytes_total[5m]))", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },

    {
      "type": "row",
      "title": "webook 应用（Go）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "QPS",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(webook_core_http_requests_total[5m]))" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "stat",
      "title": "5xx 错误率",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(webook_core_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(webook_core_http_requests_total[5m])) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "type": "stat",
      "title": "P99 延迟",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(webook_core_http_requests_duration_seconds_bucket[5m])) by (le))" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Goroutines",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "go_goroutines{job=\"webook-core\"}" }]
    },
    {
      "type": "stat",
      "title": "堆内存",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "go_memstats_alloc_bytes{job=\"webook-core\"}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "stat",
      "title": "进程 CPU",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(process_cpu_seconds_total{job=\"webook-core\"}[5m]) * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "timeseries",
      "title": "QPS 按 pattern",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(webook_core_http_requests_total[5m])) by (pattern)", "legendFormat": "{{pattern}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "响应延迟分位数",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(webook_core_http_requests_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(webook_core_http_requests_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(webook_core_http_requests_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "GC 暂停与频率",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "go_gc_duration_seconds{job=\"webook-core\", quantile=\"0.99\"}", "legendFormat": "GC P99 暂停" },
        { "expr": "rate(go_gc_duration_seconds_count{job=\"webook-core\"}[5m])", "legendFormat": "GC 次数/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "文件描述符",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_open_fds{job=\"webook-core\"}", "legendFormat": "打开" },
        { "expr": "process_max_fds{job=\"webook-core\"}", "legendFormat": "上限" }
      ]
    },

    {
      "type": "row",
      "title": "MySQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "活跃连接",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "mysql_global_status_threads_connected" }]
    },
    {
      "type": "stat",
      "title": "最大连接",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "mysql_global_variables_max_connections" }]
    },
    {
      "type": "stat",
      "title": "慢查询 rate",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(mysql_global_status_slow_queries[5m])" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "mysql_global_status_uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "命令速率（QPS 分类型）",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(mysql_global_status_commands_total[5m])", "legendFormat": "{{command}}" }]
    },
    {
      "type": "timeseries",
      "title": "InnoDB 缓冲池命中率",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "1 - rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m])", "legendFormat": "hit ratio" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },

    {
      "type": "row",
      "title": "Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "已用内存",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_memory_used_bytes" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "stat",
      "title": "连接数",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "redis_connected_clients" }]
    },
    {
      "type": "stat",
      "title": "命令速率",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_commands_processed_total[5m])" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "stat",
      "title": "命中率",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 0.95 }] } } }
    },
    {
      "type": "timeseries",
      "title": "热点命令（TopN by rate）",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 61 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "topk(10, rate(redis_commands_total[5m]))", "legendFormat": "{{cmd}}" }]
    },
    {
      "type": "timeseries",
      "title": "key 过期/驱逐",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 61 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_expired_keys_total[5m])", "legendFormat": "expired/s" },
        { "expr": "rate(redis_evicted_keys_total[5m])", "legendFormat": "evicted/s" }
      ]
    },

    {
      "type": "row",
      "title": "Kafka",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Broker 数",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 69 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "kafka_brokers" }]
    },
    {
      "type": "stat",
      "title": "Topic 数",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 69 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(count by (topic)(kafka_topic_partitions))" }]
    },
    {
      "type": "stat",
      "title": "总消费 lag",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 69 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag)" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] } } }
    },
    {
      "type": "stat",
      "title": "生产速率",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 69 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(kafka_topic_partition_current_offset[5m]))" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "timeseries",
      "title": "按 topic 消息速率",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 74 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[5m]))", "legendFormat": "{{topic}}" }]
    },
    {
      "type": "timeseries",
      "title": "按消费组 lag",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 74 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}} / {{topic}}" }]
    },

    {
      "type": "row",
      "title": "监控栈自身（Prometheus / Grafana / OTel Collector）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 81 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Prometheus scrape target 数",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 82 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(up)" }]
    },
    {
      "type": "stat",
      "title": "Prometheus 时序数",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 82 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "prometheus_tsdb_head_series" }]
    },
    {
      "type": "stat",
      "title": "Prometheus TSDB 大小",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 82 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "prometheus_tsdb_storage_blocks_bytes" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "stat",
      "title": "Prometheus 查询 QPS",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 82 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(prometheus_http_requests_total{handler=\"/api/v1/query\"}[5m])" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Grafana HTTP 请求",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 87 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (status_code) (rate(grafana_http_request_duration_seconds_count[5m]))", "legendFormat": "{{status_code}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Grafana 在线用户 / datasource 查询",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 87 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "grafana_stat_totals_dashboard", "legendFormat": "dashboard 数" },
        { "expr": "rate(grafana_datasource_request_total[5m])", "legendFormat": "DS {{datasource}} {{code}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "OTel Collector 收发 span 速率",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 94 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(otelcol_receiver_accepted_spans[5m])", "legendFormat": "accepted {{receiver}}" },
        { "expr": "rate(otelcol_exporter_sent_spans[5m])", "legendFormat": "sent {{exporter}}" },
        { "expr": "rate(otelcol_exporter_send_failed_spans[5m])", "legendFormat": "FAILED {{exporter}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "OTel Collector 队列 / 丢弃",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 94 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "otelcol_exporter_queue_size", "legendFormat": "queue size {{exporter}}" },
        { "expr": "otelcol_exporter_queue_capacity", "legendFormat": "queue cap {{exporter}}" },
        { "expr": "rate(otelcol_processor_refused_spans[5m])", "legendFormat": "refused {{processor}}" },
        { "expr": "rate(otelcol_processor_dropped_spans[5m])", "legendFormat": "dropped {{processor}}" }
      ]
    },

    {
      "type": "row",
      "title": "Zipkin",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 101 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "累计接收 span",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 102 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "zipkin_collector_spans_total{transport=\"http\"}" }]
    },
    {
      "type": "stat",
      "title": "span 写入速率",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 102 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(zipkin_collector_spans_total[5m])" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "type": "stat",
      "title": "span 丢弃速率",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 102 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(zipkin_collector_spans_dropped_total[5m])" }],
      "fieldConfig": { "defaults": { "unit": "ops", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "type": "stat",
      "title": "JVM 堆使用",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 102 },
