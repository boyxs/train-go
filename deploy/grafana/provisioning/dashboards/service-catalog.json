{
  "annotations": { "list": [] },
  "description": "服务卡片墙：每个 webook-* 服务一个卡片，显示 up / QPS / 5xx / P99 四指标。加新服务自动出现，零改动。",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [
    {
      "title": "服务详情",
      "icon": "external link",
      "tooltip": "跳转到当前服务的 Webook Overview",
      "type": "link",
      "url": "/d/webook-overview?var-service=${__field.labels.job}",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "服务卡片（按 job 自动展开）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "$service · 存活",
      "description": "up=1 表示 Prometheus 抓得到 /metrics（应用进程在跑）",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up{job=\"$service\"}", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "repeat": "service",
      "repeatDirection": "h",
      "maxPerRow": 4,
      "links": [
        { "title": "→ Webook Overview ($service)", "url": "/d/webook-overview?var-service=$service", "targetBlank": false }
      ]
    },
    {
      "type": "row",
      "title": "QPS（按 service 拆分）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "QPS",
      "description": "实时 QPS 按 service 染色对比",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(webook_http_requests_total[5m]))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } },
      "links": [
        { "title": "→ Webook Overview", "url": "/d/webook-overview?var-service=All", "targetBlank": false }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx 错误率",
      "description": "按 service 比对错误率，单位 %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(webook_http_requests_total{status=~\"5..\"}[5m])) / sum by (job) (rate(webook_http_requests_total[5m])) * 100", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "P99 延迟",
      "description": "按 service 比对 P99 响应时间。chat 默认更高（SSE 流式正常 >1s）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (job, le) (rate(webook_http_requests_duration_seconds_bucket[5m])))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Goroutines",
      "description": "按 service 比对 goroutine 数量；持续上涨疑似泄漏",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (go_goroutines{job=~\"webook-.*\"})", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "type": "row",
      "title": "依赖（共享）",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "DB 查询 QPS（按 service）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(webook_db_query_total[5m]))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "qps", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Redis 命令 QPS（按 service）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (job) (rate(webook_redis_cmd_total[5m]))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["webook", "catalog", "overview"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(up{job=~\"webook-.*\"}, job)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": "webook-.*",
        "current": { "text": "All", "value": "$__all", "selected": false }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["10s", "30s", "1m", "5m"] },
  "timezone": "",
  "title": "Webook Service Catalog",
  "uid": "webook-service-catalog"
}
