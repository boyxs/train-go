# ===================================================
# dev 真实环境变量
# ===================================================
GH_USER=boyxs
CORE_IMAGE_TAG=main-latest
CHAT_IMAGE_TAG=main-latest
MIGRATOR_IMAGE_TAG=main-latest
FE_IMAGE_TAG=main-latest
GHCR_REGISTRY=ghcr.io

CORE_APP_ENV=config/dev.yaml
CHAT_APP_ENV=config/dev.yaml
MIGRATOR_APP_ENV=config/dev.yaml
DEPLOY_ENV=dev

MYSQL_PASS=13520
REDIS_PASS=13520

# ── 业务/中间件内存
MYSQL_MEM=768m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=768m
ES_HEAP=-Xms384m -Xmx384m
FE_MEM=384m
OLLAMA_MEM=1024m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener（server 模式填部署机 IP）
KAFKA_EXTERNAL_HOST=192.168.150.101
KAFKA_EXTERNAL_PORT=9094

# ── Etcd
ETCD_ALLOW_NONE=yes
ETCD_PASS=13520
ETCD_MEM=128m

# ── 宿主端口
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://localhost:3001/
ZIPKIN_PORT=9411

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
