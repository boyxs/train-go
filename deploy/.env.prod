# ===================================================
# prod 真实环境变量（上线前改 MYSQL_PASS / REDIS_PASS / GRAFANA_PASS 强密码）
# ===================================================
GH_USER=boyxs
CORE_IMAGE_TAG=1.0.0
CHAT_IMAGE_TAG=1.0.0
MIGRATOR_IMAGE_TAG=1.0.0
COMMENT_IMAGE_TAG=1.0.0
INTERACTION_IMAGE_TAG=1.0.0
WORKER_IMAGE_TAG=1.0.0
FE_IMAGE_TAG=1.0.0
GHCR_REGISTRY=ghcr.io

CORE_APP_ENV=config/prod.yaml
CHAT_APP_ENV=config/prod.yaml
MIGRATOR_APP_ENV=config/prod.yaml
COMMENT_APP_ENV=config/prod.yaml
INTERACTION_APP_ENV=config/prod.yaml
WORKER_APP_ENV=config/prod.yaml
DEPLOY_ENV=prod

MYSQL_PASS=13520
REDIS_PASS=13520

# ── 业务/中间件内存（足配）
MYSQL_MEM=1536m
REDIS_MEM=256m
KAFKA_MEM=1024m
KAFKA_HEAP=-Xmx768m -Xms768m
ES_MEM=2048m
ES_HEAP=-Xms1024m -Xmx1024m
FE_MEM=512m
OLLAMA_MEM=2048m

# ── 监控栈内存
PROMETHEUS_MEM=1024m
GRAFANA_MEM=512m
ZIPKIN_MEM=1024m
ZIPKIN_HEAP=-Xms512m -Xmx512m
OTEL_MEM=512m
NGINX_MEM=256m

# ── Kafka EXTERNAL listener
KAFKA_EXTERNAL_HOST=192.168.150.101
KAFKA_EXTERNAL_PORT=9294

# ── Etcd
ETCD_ALLOW_NONE=yes
ETCD_PASS=13520
ETCD_MEM=256m

# ── 宿主端口（和 dev/staging 错开）
NGINX_PORT=82
PROMETHEUS_PORT=9290
GRAFANA_PORT=3021
GRAFANA_ROOT_URL=http://localhost:3021/
ZIPKIN_PORT=9413

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
