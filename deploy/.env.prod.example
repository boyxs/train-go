# ===================================================
# prod 环境变量模板（上线前改强密码）
# 发版方式（按服务独立打 tag）：
#   git tag webook-core-v1.1.0 && git push --tags
#   git tag webook-chat-v1.1.0 && git push --tags
#   git tag webook-fe-v1.1.0   && git push --tags
#   git tag webook-migrator-v1.2.1 && git push --tags
#   git tag webook-interaction-v1.1.0 && git push --tags
#   git tag webook-comment-v0.1.0 && git push --tags
#   git tag webook-relation-v0.1.0 && git push --tags
#   git tag webook-worker-v1.1.0 && git push --tags
# 推 tag 后必须同步更新下方对应 *_IMAGE_TAG 与 tag 一致（见根 CLAUDE.md「发版流程」）
# ===================================================

# ── 镜像与发布 ─────────────────────────────────────────
GH_USER=your-github-username
GHCR_REGISTRY=ghcr.io
CORE_IMAGE_TAG=1.3.0
CHAT_IMAGE_TAG=1.2.0
COMMENT_IMAGE_TAG=0.1.0
INTERACTION_IMAGE_TAG=0.1.0
RELATION_IMAGE_TAG=0.1.0
TAG_IMAGE_TAG=0.1.0
SEARCH_IMAGE_TAG=0.1.0
MIGRATOR_IMAGE_TAG=1.2.1
WORKER_IMAGE_TAG=0.1.0
FE_IMAGE_TAG=1.2.0

# ── 环境选择（APP_ENV 决定加载哪份 yaml） ─────────────────────
CORE_APP_ENV=config/prod.yaml
CHAT_APP_ENV=config/prod.yaml
COMMENT_APP_ENV=config/prod.yaml
INTERACTION_APP_ENV=config/prod.yaml
RELATION_APP_ENV=config/prod.yaml
TAG_APP_ENV=config/prod.yaml
SEARCH_APP_ENV=config/prod.yaml
MIGRATOR_APP_ENV=config/prod.yaml
WORKER_APP_ENV=config/prod.yaml
DEPLOY_ENV=prod

# ── 密码 / 密钥（敏感，勿提交真实值；集中便于审计与轮换） ──────────────────
# 自建中间件
MYSQL_PASS=CHANGE_ME_STRONG
REDIS_PASS=CHANGE_ME_STRONG
# 固定 canal（写死在 mysql/init/01-canal-user.sql）
CANAL_PASS=canal
ES_PASS=CHANGE_ME_STRONG    # ES 内置 elastic 用户密码（≥6 位）；webook-es ELASTIC_PASSWORD + core/migrator data.es.password
# etcd 认证（切官方 quay.io/coreos/etcd 后不用，保留供切回 bitnami 镜像）
# ETCD_ALLOW_NONE=yes
# ETCD_PASS=CHANGE_ME_STRONG
# Grafana 登录 + SMTP 授权码
GRAFANA_PASS=CHANGE_ME_STRONG
GRAFANA_SMTP_PASSWORD=
# 外部 LLM / Embedding
DEEPSEEK_API_KEY=
KIMI_API_KEY=
QIANFAN_API_KEY=

# ── 内存 / 堆 ────────────────────────────────────────
# 业务服务（Go：mem_limit cgroup 硬限 / GOMEMLIMIT 软限留 ~12% buffer 给堆外 / GOGC=80 比默认 100 激进）
CORE_MEM=768m
CORE_GOMEMLIMIT=680MiB
CORE_GOGC=80
CHAT_MEM=512m
CHAT_GOMEMLIMIT=450MiB
CHAT_GOGC=80
COMMENT_MEM=512m
COMMENT_GOMEMLIMIT=450MiB
COMMENT_GOGC=80
MIGRATOR_MEM=512m
MIGRATOR_GOMEMLIMIT=450MiB
MIGRATOR_GOGC=80
# 中间件
MYSQL_MEM=1536m
REDIS_MEM=256m
KAFKA_MEM=1024m
KAFKA_HEAP=-Xmx768m -Xms768m
ES_MEM=2048m
ES_HEAP=-Xms1024m -Xmx1024m
FE_MEM=512m
OLLAMA_MEM=2048m
ETCD_MEM=256m
# 监控栈
PROMETHEUS_MEM=1024m
GRAFANA_MEM=512m
ZIPKIN_MEM=1024m
ZIPKIN_HEAP=-Xms512m -Xmx512m
OTEL_MEM=512m
NGINX_MEM=256m

# ── 端口 / 网络 ───────────────────────────────────────
NGINX_PORT=82
PROMETHEUS_PORT=9290
GRAFANA_PORT=3021
# grafana root_url（告警邮件链接用）；经域名/HTTPS 访问改完整 URL，如 https://monitor.webook.com/
GRAFANA_ROOT_URL=http://localhost:3021/
ZIPKIN_PORT=9413
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9294
# CHAT_HOST_PORT=8020   # 仅 local override 用；server 模式 chat 走 docker 内网 + nginx，无需暴露

# ── Grafana / 告警（非敏感） ─────────────────────────────
GRAFANA_USER=admin
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Webook Monitor
ALERT_EMAIL_TO=
