# ===================================================
# local 真实环境变量
# ===================================================
GH_USER=local
IMAGE_TAG=local
FE_IMAGE_TAG=local

APP_ENV=config/dev.yaml
DEPLOY_ENV=local

MYSQL_PASS=13520
REDIS_PASS=13520

# ── 业务/中间件内存
MYSQL_MEM=1024m
REDIS_MEM=128m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener（主机访问 kafka 时 advertised 的地址）
# local 模式：localhost:9094；server 模式：填服务器外网/内网 IP
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9094

# ── Etcd
ETCD_ALLOW_NONE=yes          # yes=无需认证；no=必须配 ETCD_PASS
ETCD_PASS=13520
ETCD_MEM=128m

# ── 宿主端口
WEBOOK_HOST_PORT=8089
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
ETCD_HOST_PORT=2379
KAFKA_HOST_PORT=9092
KAFKA_EXTERNAL_HOST_PORT=9094
ES_HOST_PORT=9200
OLLAMA_HOST_PORT=11434
OTEL_HOST_PORT=4317
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ZIPKIN_PORT=9411

# ── Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_SMTP_ENABLED=true
GRAFANA_SMTP_HOST=smtp.qq.com:587
GRAFANA_SMTP_USER=3236447743@qq.com
GRAFANA_SMTP_PASSWORD=srbajulsawyhdbda
GRAFANA_SMTP_FROM_ADDRESS=3236447743@qq.com
GRAFANA_SMTP_FROM_NAME=Webook Alert
ALERT_EMAIL_TO=3236447743@qq.com
