# ===================================================
# staging 真实环境变量
# ===================================================
GH_USER=boyxs
CORE_IMAGE_TAG=main-latest
CHAT_IMAGE_TAG=main-latest
MIGRATOR_IMAGE_TAG=main-latest
FE_IMAGE_TAG=main-latest
GHCR_REGISTRY=ghcr.io

CORE_APP_ENV=config/staging.yaml
CHAT_APP_ENV=config/staging.yaml
MIGRATOR_APP_ENV=config/staging.yaml
DEPLOY_ENV=staging

MYSQL_PASS=13520
REDIS_PASS=13520

# ── 业务/中间件内存
MYSQL_MEM=1024m
REDIS_MEM=256m
KAFKA_MEM=768m
KAFKA_HEAP=-Xmx512m -Xms512m
ES_MEM=1024m
ES_HEAP=-Xms512m -Xmx512m
FE_MEM=512m
OLLAMA_MEM=2048m

# ── 监控栈内存
PROMETHEUS_MEM=512m
GRAFANA_MEM=256m
ZIPKIN_MEM=512m
ZIPKIN_HEAP=-Xms256m -Xmx256m
OTEL_MEM=256m
NGINX_MEM=128m

# ── Kafka EXTERNAL listener
KAFKA_EXTERNAL_HOST=192.168.150.101
KAFKA_EXTERNAL_PORT=9194

# ── Etcd
ETCD_ALLOW_NONE=yes
